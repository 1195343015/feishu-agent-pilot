{
  "name": "feishu-agent-pilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev -w @agent-pilot/server\" \"npm run dev -w @agent-pilot/web\"",
    "dev:web": "npm run dev -w @agent-pilot/web",
    "dev:server": "npm run dev -w @agent-pilot/server",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  }
}
